# A2A Trust PoC — Environment Configuration
# Copy to .env and fill in values. Never commit .env.

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SECRETS_NAME=

# ── Storage ───────────────────────────────────────────────────────────────────
S3_BUCKET=
DYNAMODB_TABLE=

# ── Services ──────────────────────────────────────────────────────────────────
MCP_PORT=
ADMIN_PORT=
DEMO_PORT=
LOG_LEVEL=

# ── Cedar ─────────────────────────────────────────────────────────────────────
CEDAR_POLICY_PATH=

# ── Audit ─────────────────────────────────────────────────────────────────────
CLOUDWATCH_LOG_GROUP=
